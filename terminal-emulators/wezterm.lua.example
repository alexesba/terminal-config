-- wezterm.lua — personal WezTerm configuration
--
-- This file is NOT tracked in your home directory (installed from this template).
-- Copy wezterm.lua.example → ~/.config/wezterm/wezterm.lua via install.sh.
-- colors.lua (written by `colorscheme`) lives alongside this file in the same dir.

local wezterm = require('wezterm')

local config = {
  color_scheme = 'Sonokai (Gogh)',
  -- default_prog is intentionally unset — WezTerm will use $SHELL as a login
  -- shell automatically, which works correctly for any shell (zsh, fish, nushell, etc.)
  font_size = 14.0,
  window_decorations = 'RESIZE',
  enable_tab_bar = false,
  use_fancy_tab_bar = false,
  force_reverse_video_cursor = true,
  default_cursor_style = 'BlinkingBlock',
  cursor_blink_rate = 500,
  freetype_load_flags = 'NO_HINTING',
  font = wezterm.font({
    family = '{{FONT_FAMILY}}',
    harfbuzz_features = {"calt=1", "clig=1", "liga=1"},
  })
}

-- Persisted Gogh theme from `colorscheme` → ~/.config/wezterm/colors.lua.
-- Config reload (watch list) updates every pane — parent shell, tmux, splits,
-- and window padding — without per-pane OSC escape sequences.
local colors_path = wezterm.config_dir .. '/colors.lua'
wezterm.add_to_config_reload_watch_list(colors_path)

local function gogh_background_layer(color)
  return {
    {
      source = { Color = color },
      width = '100%',
      height = '100%',
    },
  }
end

local function load_gogh_theme()
  local f = io.open(colors_path, 'r')
  if not f then
    return nil, nil
  end
  f:close()
  local ok, data = pcall(dofile, colors_path)
  if not ok or type(data) ~= 'table' or not data.foreground then
    return nil, nil
  end
  local scheme_name = data.scheme_name
  if type(scheme_name) ~= 'string' or scheme_name == '' then
    scheme_name = 'Sonokai (Gogh)'
  end
  local colors = {
    foreground = data.foreground,
    background = data.background,
    ansi = data.ansi,
    brights = data.brights,
  }
  if data.cursor_bg then
    colors.cursor_bg = data.cursor_bg
    colors.cursor_border = data.cursor_border
  end
  return scheme_name, colors
end

local scheme_name, colors = load_gogh_theme()
if colors then
  config.color_schemes = {
    [scheme_name] = colors,
  }
  config.color_scheme = scheme_name
  config.background = gogh_background_layer(colors.background)
end

wezterm.on('window-config-reloaded', function(window)
  local effective = window:effective_config()
  local bg = effective.colors and effective.colors.background
  if bg then
    window:set_config_overrides({
      background = gogh_background_layer(bg),
    })
  end
end)

return config
