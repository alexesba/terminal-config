# custom.sh — personal overrides loaded by rc.sh (both bash and zsh)
#
# This file is NOT tracked by git (see .gitignore).
# Copy custom.sh.example → custom.sh and customise freely.
#
# Good things to put here:
#   • Private API keys / tokens (export GITHUB_TOKEN="...")
#   • Machine-specific PATH entries
#   • Work-only aliases
#   • Language server / tool paths

# ── Example: extra PATH entries ───────────────────────────────────────────────
# export PATH="$HOME/.cargo/bin:$PATH"
# export PATH="$HOME/go/bin:$PATH"

# ── Example: default editor ───────────────────────────────────────────────────
# export EDITOR=nvim
# export VISUAL=nvim

# ── Example: gogh checkout directory (used by colorscheme() function) ─────────
# Point this at your Gogh repo root; themes are read from its installs/ subdir.
# export GOGH_DIR="$HOME/src/gogh"

# ── Terminal emulator (used by gogh / colorscheme to target the right app) ────
# install.sh replaces the {{TERMINAL}} placeholder below with your terminal
# choice (alacritty/kitty/wezterm) and uncomments it. Edit by hand to override.
# export TERMINAL={{TERMINAL}}

# ── Terminal font (written into emulator config by install.sh) ────────────────
# export TERMINAL_FONT={{TERMINAL_FONT}}

# ── Example: work aliases ─────────────────────────────────────────────────────
# alias work='cd ~/Projects/work'
