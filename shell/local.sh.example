# ~/.local.sh — personal env and secrets loaded by rc.sh (both bash and zsh)
#
# install.sh copies this template to ~/.local.sh on first run (not into the repo).
# Edit ~/.local.sh freely — it lives in your home directory.
#
# Good things to put here:
#   • Private API keys / tokens (export GITHUB_TOKEN="...")
#   • Machine-specific PATH entries
#   • ZSH_THEME, TERMINAL, GOGH_DIR, EDITOR, and other exports
#   • Language server / tool paths
#
# For aliases, use ~/.bash_aliases (see shell/README.md) — not this file.

# ── Example: extra PATH entries ───────────────────────────────────────────────
# export PATH="$HOME/.cargo/bin:$PATH"
# export PATH="$HOME/go/bin:$PATH"

# ── Example: default editor ───────────────────────────────────────────────────
# install.sh can set this for you (Set EDITOR=nvim? during install).
# export EDITOR=nvim
# export VISUAL=nvim

# ── Example: gogh checkout directory (used by colorscheme() function) ─────────
# Point this at your Gogh repo root; themes are read from its installs/ subdir.
# export GOGH_DIR="$HOME/src/gogh"

# ── Terminal emulator (used by gogh / colorscheme to target the right app) ────
# install.sh replaces the {{TERMINAL}} placeholder below with your terminal
# choice (alacritty/kitty/wezterm) and uncomments it. Edit by hand to override.
# export TERMINAL={{TERMINAL}}

# ── Terminal font (written into emulator config by install.sh) ────────────────
# export TERMINAL_FONT={{TERMINAL_FONT}}
# export TERMINAL_FONT_ID={{TERMINAL_FONT_ID}}

# ── Example: disable dotfiles update notice on shell startup ────────────────
# export TERMINAL_CONFIG_UPDATE_CHECK=0

# ── Example: zsh history (defaults in shell/zsh/history.sh — override here) ───
# export HISTFILE="$HOME/.zsh_history"
# export HISTSIZE=50000
# export SAVEHIST=20000
