# tmux.conf — personal tmux configuration
#
# This file is NOT tracked by git (see .gitignore).
# Copy tmux.conf.example → tmux.conf and customise freely.
# install.sh symlinks ~/.tmux.conf → tmux.conf in this repo.

set -sg escape-time 0

# set-window-option -g mode-keys vi
setw -g mode-keys vi

# Easy config reload
bind-key R source-file ~/.tmux.conf \; display-message "tmux.conf reloaded"

# use vim-like keys for splits and windows
bind-key v split-window -h
bind-key s split-window -v
bind-key h select-pane -L
bind-key j select-pane -D
bind-key k select-pane -U
bind-key l select-pane -R

bind P paste-buffer

# Setup 'v' to begin selection as in Vim
bind-key -T copy-mode-vi v send -X begin-selection
# Clipboard: pbcopy on macOS, clip.exe on WSL, xclip on Linux
if-shell "uname | grep -q Darwin" \
  'bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel "pbcopy"; \
   bind-key -T copy-mode-vi Enter send -X copy-pipe-and-cancel "pbcopy"' \
  'if-shell "grep -qi microsoft /proc/version 2>/dev/null" \
    "bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel \"clip.exe\"; \
     bind-key -T copy-mode-vi Enter send -X copy-pipe-and-cancel \"clip.exe\"" \
    "bind -T copy-mode-vi y send-keys -X copy-pipe-and-cancel \"xclip -in -selection clipboard\"; \
     bind-key -T copy-mode-vi Enter send -X copy-pipe-and-cancel \"xclip -in -selection clipboard\""'

bind -n C-k clear-history
bind < resize-pane -L 1
bind > resize-pane -R 1
bind - resize-pane -D 1
bind + resize-pane -U 1

set -g set-titles off
set-option -g focus-events on
if-shell "uname | grep -q Darwin" 'set-option -g default-shell /bin/zsh'
set -g default-terminal "tmux-256color"
set-option -sa terminal-overrides ',xterm-256color:RGB'

set -ga terminal-overrides '*:Ss=\E[%p1%d q:Se=\E[ q' # this is for the cursor shape

not_tmux="ps -o state= -o comm= -t '#{pane_tty}' | grep -iqE '^[^TXZ ]+ +(\\S+\\/)?(g?(view|n?vim?x?)(diff)?|fzf)$'"
bind-key -n C-h if-shell "$not_tmux" "send-keys C-h"  "select-pane -L"
bind-key -n C-j if-shell "$not_tmux" "send-keys C-j"  "select-pane -D"
bind-key -n C-k if-shell "$not_tmux" "send-keys C-k"  "select-pane -U"

set -g visual-activity on
setw -g monitor-activity on

# -----------#
# Status bar #
# -----------#
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on            # keep window numbers gap-free when one closes

set -g status-interval 5              # refresh the clock every 5s
set -g status-justify left

# Blend the bar into the active colour scheme. Using palette colours 0–15 means
# the bar re-themes itself automatically whenever you run `colorscheme`.
set -g status-style 'bg=default,fg=colour245'
set -g status-left-length 40
set -g status-right-length 60

# Session name — rounded pill on the left (green)
set -g status-left '#[fg=colour2]#[fg=colour0,bg=colour2,bold] #S #[fg=colour2,bg=default] '

# Date + time — rounded pill on the right
set -g status-right '#[fg=colour240]#[fg=colour15,bg=colour240] %a %d %b #[fg=colour250]%H:%M #[fg=colour240,bg=default] '

# Window tabs — muted when inactive, accent pill when active
set -g window-status-separator ''
setw -g window-status-format '#[fg=colour244,bg=default]  #I #W#{?window_zoomed_flag,  ,} '
setw -g window-status-current-format ' #[fg=colour7]#[fg=colour0,bg=colour7,bold] #I #W#{?window_zoomed_flag,  ,}#[fg=colour7,bg=default]'
setw -g window-status-activity-style 'fg=colour3,bold'

# Borders + messages share the accent colour
set -g pane-active-border-style 'fg=colour4'
set -g pane-border-style 'fg=colour238'
set -g message-style 'fg=colour0,bg=colour7'
set -g mode-style 'fg=colour0,bg=colour7'

# ── Plugins (TPM — Tmux Plugin Manager) ──────────────────────────────────────
# Install TPM: bootstrap.sh --tmux will do this automatically, or run:
#   git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'tmux-plugins/tmux-resurrect'   # prefix + Ctrl-s save / Ctrl-r restore
set -g @plugin 'tmux-plugins/tmux-continuum'   # auto-save every 15 min

set -g @continuum-restore 'on'
set -g @resurrect-capture-pane-contents 'on'

# Initialize TPM — must stay at the very bottom of tmux.conf
run '~/.tmux/plugins/tpm/tpm'


