# Personal overrides — copy *.example → local file to customise
shell/custom.sh
shell/bash_custom.sh

# CI workflows (negate a global ~/.gitignore that ignores .github)
!.github/
!.github/workflows/
!.github/workflows/*.yml

# Backup files created by install.sh link_file helper
*.old

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor swap / temp files
*.swp
*.swo
*~

# Environment / secrets
.env
.env.*
